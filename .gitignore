# =============================================================================
# .gitignore for ETH Trading Bot
# =============================================================================

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
bot/.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.venv/
venv/
ENV/

# --- Node.js / Next.js ---
node_modules/
.next/
out/
.turbo/
.vercel

# --- Database ---
data/
*.db
*.sqlite
*.sqlite3

# --- Logs ---
logs/
*.log

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Misc ---
*.bak
*.tmp
.cache/
coverage/
.nyc_output/

# --- Non-project files ---
skills/
CLAUDE.md
AGENTS.md
worklog.md
download/
