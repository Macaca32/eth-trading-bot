# =============================================================================
# ETH Trading Bot - Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to git!
# =============================================================================

# -- Trading Mode --
# Options: paper (testnet) | live (mainnet)
TRADING_MODE=paper

# -- Wallet Configuration --
# Your wallet private key (required for live trading, optional for paper)
# Generate from MetaMask → Account Details → Export Private Key
WALLET_PRIVATE_KEY=
# Your wallet address (used for querying account state)
WALLET_ADDRESS=

# -- Risk Management --
# Maximum risk per trade as % of equity (default: 1.5)
MAX_RISK_PER_TRADE_PCT=1.5
# Maximum daily loss as % of equity (default: 7.0)
MAX_DAILY_RISK_PCT=7.0
# Maximum concurrent positions (default: 5)
MAX_CONCURRENT_POSITIONS=5
# Maximum % of equity that can be deployed (default: 50)
MAX_CAPITAL_DEPLOYED_PCT=50
# Consecutive losses before circuit breaker triggers (default: 5)
CIRCUIT_BREAKER_LOSSES=5
# Minutes to pause after circuit breaker triggers (default: 30)
CIRCUIT_BREAKER_PAUSE_MINUTES=30

# -- Data Pipeline --
# Default candle timeframe: 1m, 5m, 15m, 1h, 4h, 1d
DEFAULT_TIMEFRAME=1h

# -- Optimization --
# Number of Optuna trials per optimization run (default: 200)
OPTUNA_N_TRIALS=200

# -- Logging --
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Log file path (relative to bot/ directory)
LOG_FILE=logs/bot.log
